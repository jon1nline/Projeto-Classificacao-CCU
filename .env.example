# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database
# SQLite (desenvolvimento): DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (produção): DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/neila_db

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
